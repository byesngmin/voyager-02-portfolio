{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "Skill(update-config)",
      "Skill(update-config:*)"
    ],
    "deny": [
      "WebSearch",
      "WebFetch"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"c:/Users/user/Documents/New project 2/.claude/hooks/gemini-router.js\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"c:/Users/user/Documents/New project 2/.claude/hooks/agent-guard.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"c:/Users/user/Documents/New project 2/.claude/hooks/post-task-check.js\""
          }
        ]
      }
    ]
  }
}
